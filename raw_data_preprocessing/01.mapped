## *S. skua* — `01e.mapeo_sskua.sh`

```bash
#!/bin/bash
export TZ="America/Santiago"
source activate preSNPcalling

ref="/data2/lab2/lucila/01.anotacion/SterChil1.hic.hap1.yahs_scaffolds_final.fa.MicroFinder.ordered.fa.masked"
bam="/data2/lab2/lucila/BIO295B_FernandaCavieres/data/bam_completo_norte_final"
mik="/data2/lab2/lucila/data_set_final/genomas_mikkelsen"
high3="/data2/lab2/lucila/data_set_final/genomas_norte/bam_pool3/bam_highcoverage"
low3="/data2/lab2/lucila/data_set_final/genomas_norte/bam_pool3/bam_lowcoverage"

echo "[$(date '+%H:%M:%S')] Iniciando mapeo S. skua"

# SRR simples
for SM in SRR22267302 SRR22267303; do
    echo "[$(date '+%H:%M:%S')] Mapeando: $SM"
    bwa-mem2 mem -t 8 -M \
        -R "@RG\tID:${SM}\tLB:${SM}\tPL:ILLUMINA\tPU:skua_skua\tSM:${SM}" \
        "$ref" "$mik/${SM}_1.fq.gz" "$mik/${SM}_2.fq.gz" | \
    samtools view -bh -@ 8 -q 30 -f 0x2 > "$bam/${SM}.bam" && \
    echo "[$(date '+%H:%M:%S')] OK: $SM" || echo "[$(date '+%H:%M:%S')] ERROR: $SM"
done

# S_2019 con high+low
for SM in S1_2019 S3_2019 S4_2019 S5_2019 S6_2019 S7_2019; do
    echo "[$(date '+%H:%M:%S')] Mapeando high: $SM"
    bwa-mem2 mem -t 8 -M \
        -R "@RG\tID:${SM}_high\tLB:${SM}\tPL:ILLUMINA\tPU:skua_skua\tSM:${SM}" \
        "$ref" "$high3/${SM}_R1.fastq.gz" "$high3/${SM}_R2.fastq.gz" | \
    samtools view -bh -@ 8 -q 30 -f 0x2 > "$bam/${SM}_high.bam" && \
    echo "[$(date '+%H:%M:%S')] OK high: $SM" || echo "[$(date '+%H:%M:%S')] ERROR high: $SM"

    echo "[$(date '+%H:%M:%S')] Mapeando low: $SM"
    bwa-mem2 mem -t 8 -M \
        -R "@RG\tID:${SM}_low\tLB:${SM}\tPL:ILLUMINA\tPU:skua_skua\tSM:${SM}" \
        "$ref" "$low3/${SM}_R1.fastq.gz" "$low3/${SM}_R2.fastq.gz" | \
    samtools view -bh -@ 8 -q 30 -f 0x2 > "$bam/${SM}_low.bam" && \
    echo "[$(date '+%H:%M:%S')] OK low: $SM" || echo "[$(date '+%H:%M:%S')] ERROR low: $SM"
done

echo "============================================"
echo "Mapeo S. skua terminado"
echo "============================================"
```
