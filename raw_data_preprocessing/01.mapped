        -R "@RG\tID:${SM}_low\tLB:${SM}\tPL:ILLUMINA\tPU:skua_longicaudus\tSM:${SM}" \
        "$ref" "$low3/${SM}_R1.fastq.gz" "$low3/${SM}_R2.fastq.gz" | \
    samtools view -bh -@ 8 -q 30 -f 0x2 > "$bam/${SM}_low.bam" && \
    echo "[$(date '+%H:%M:%S')] OK low: $SM" || echo "[$(date '+%H:%M:%S')] ERROR low: $SM"
done

echo "============================================"
echo "Mapeo S. longicaudus terminado"
echo "============================================"
